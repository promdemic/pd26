rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Event info is public to read; only admins can write
    match /eventInfo/{docId} {
      allow read: if true;
      allow write: if request.auth != null
                   && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Admins can only read their own record; no client writes (manage via Console)
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Each student can read and write only their own RSVP
    match /rsvps/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Authenticated users can read all volunteer docs (for slot counting)
    // Each parent can only write their own doc
    match /volunteers/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
